<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d %p %c{2} %m%n"/>
        </Console>

        <!-- FILE APPENDER -->
        <File name="CinemaLog" fileName="logs/File.log">
            <PatternLayout pattern="File Appender: %d %p %c{2} %m%n" />
        </File>
    </Appenders>
    <Loggers>
        <!-- LOGGER -->
        <Logger name="ru.job4j.cinema.repository" level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="CinemaLog" />
        </Logger>
        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>